# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Supabase — get from https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Groq — get from https://console.groq.com → API Keys (free tier available)
VITE_GROQ_API_KEY=gsk_your-key-here

# Serper — web search for the AI Coach (places, gyms, news, etc.)
# Get 2500 free queries at serper.dev (no credit card)
VITE_SERPER_API_KEY=your-serper-key-here

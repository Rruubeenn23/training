# Copy this file to .env.local and fill in your values
# These are SAFE to expose (Supabase anon key is meant to be public)
# Also add these as environment variables in your Netlify dashboard

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: default Groq API key (users can override in Settings)
# VITE_GROQ_API_KEY=gsk_...
